{
  name: "qwerty-halcyon_elora",
  short: "QWERTY (Halcyon)",
  // Halcyon-specific QWERTY variant. Alpha core + number row match
  // the generic qwerty.json. The left outer-pinky column is
  // reassigned to the modcolumn (Tab/CapsLock/Shift) since halcyon
  // has no dedicated modcolumn and typists typically bind those to
  // firmware layers. Right outer-pinky stays punctuation + Enter.
  mappings: {
    main_k1:  { char: ["q", "Q"] },
    main_k2:  { char: ["w", "W"] },
    main_k3:  { char: ["e", "E"] },
    main_k4:  { char: ["r", "R"] },
    main_k5:  { char: ["t", "T"] },
    main_k6:  { char: ["y", "Y"] },
    main_k7:  { char: ["u", "U"] },
    main_k8:  { char: ["i", "I"] },
    main_k9:  { char: ["o", "O"] },
    main_k10: { char: ["p", "P"] },

    main_k11: { char: ["a", "A"] },
    main_k12: { char: ["s", "S"] },
    main_k13: { char: ["d", "D"] },
    main_k14: { char: ["f", "F"] },
    main_k15: { char: ["g", "G"] },
    main_k16: { char: ["h", "H"] },
    main_k17: { char: ["j", "J"] },
    main_k18: { char: ["k", "K"] },
    main_k19: { char: ["l", "L"] },
    main_k20: { char: [";", ":"] },

    main_k21: { char: ["z", "Z"] },
    main_k22: { char: ["x", "X"] },
    main_k23: { char: ["c", "C"] },
    main_k24: { char: ["v", "V"] },
    main_k25: { char: ["b", "B"] },
    main_k26: { char: ["n", "N"] },
    main_k27: { char: ["m", "M"] },
    main_k28: { char: [",", "<"] },
    main_k29: { char: [".", ">"] },
    main_k30: { char: ["/", "?"] },

    main_k31: { char: ["1", "!"] },
    main_k32: { char: ["2", "@"] },
    main_k33: { char: ["3", "#"] },
    main_k34: { char: ["4", "$"] },
    main_k35: { char: ["5", "%"] },
    main_k36: { char: ["6", "^"] },
    main_k37: { char: ["7", "&"] },
    main_k38: { char: ["8", "*"] },
    main_k39: { char: ["9", "("] },
    main_k40: { char: ["0", ")"] },

    // left outer-pinky column = modcolumn
    main_k41: { char: ["`", "~"] },
    main_k42: { named: "tab" },
    main_k43: { named: "capslock" },
    main_k44: { named: "shift" },

    // right outer-pinky column = punctuation + enter
    main_k46: { char: ["-", "_"] },
    main_k47: { char: ["[", "{"] },
    main_k48: { char: ["'", "\""] },
    main_k49: { named: "enter" },
  },
}
