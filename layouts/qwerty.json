{
  name: "qwerty",
  short: "QWERTY",
  // Standard US QWERTY layout keyed by main-cluster ids. Ported from
  // the old evdev-keyed layout to the new physical-id scheme. Only
  // targets main_k1..main_k47 + a handful of named mods; anything
  // the target keyboard doesn't have just stays dead.
  mappings: {
    // ---- number row ----
    main_k1:  { char: ["`", "~"] },
    main_k2:  { char: ["1", "!"] },
    main_k3:  { char: ["2", "@"] },
    main_k4:  { char: ["3", "#"] },
    main_k5:  { char: ["4", "$"] },
    main_k6:  { char: ["5", "%"] },
    main_k7:  { char: ["6", "^"] },
    main_k8:  { char: ["7", "&"] },
    main_k9:  { char: ["8", "*"] },
    main_k10: { char: ["9", "("] },
    main_k11: { char: ["0", ")"] },
    main_k12: { char: ["-", "_"] },
    main_k13: { char: ["=", "+"] },

    // ---- top row ----
    main_k14: { char: ["q", "Q"] },
    main_k15: { char: ["w", "W"] },
    main_k16: { char: ["e", "E"] },
    main_k17: { char: ["r", "R"] },
    main_k18: { char: ["t", "T"] },
    main_k19: { char: ["y", "Y"] },
    main_k20: { char: ["u", "U"] },
    main_k21: { char: ["i", "I"] },
    main_k22: { char: ["o", "O"] },
    main_k23: { char: ["p", "P"] },
    main_k24: { char: ["[", "{"] },
    main_k25: { char: ["]", "}"] },
    main_k26: { char: ["\\", "|"] },

    // ---- home row ----
    main_k27: { char: ["a", "A"] },
    main_k28: { char: ["s", "S"] },
    main_k29: { char: ["d", "D"] },
    main_k30: { char: ["f", "F"] },
    main_k31: { char: ["g", "G"] },
    main_k32: { char: ["h", "H"] },
    main_k33: { char: ["j", "J"] },
    main_k34: { char: ["k", "K"] },
    main_k35: { char: ["l", "L"] },
    main_k36: { char: [";", ":"] },
    main_k37: { char: ["'", "\""] },

    // ---- bottom row ----
    main_k38: { char: ["z", "Z"] },
    main_k39: { char: ["x", "X"] },
    main_k40: { char: ["c", "C"] },
    main_k41: { char: ["v", "V"] },
    main_k42: { char: ["b", "B"] },
    main_k43: { char: ["n", "N"] },
    main_k44: { char: ["m", "M"] },
    main_k45: { char: [",", "<"] },
    main_k46: { char: [".", ">"] },
    main_k47: { char: ["/", "?"] },

    // ---- mod column (labeled keys) ----
    mods_tab:         { named: "tab" },
    mods_capslock:    { named: "capslock" },
    mods_shift_left:  { named: "shift" },
    mods_shift_right: { named: "shift" },
    mods_enter:       { named: "enter" },
    mods_backspace:   { named: "backspace" },
  },
}
