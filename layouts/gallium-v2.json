{
  name: "gallium-v2",
  short: "Gallium v2",
  // Gallium v2 — the col-stag-optimized variant with QX and JZ
  // swaps applied. Targets the canonical main_k1..k30 alpha core
  // + number row. Outer columns (main_k41..) are layout-specific;
  // gallium doesn't prescribe them.
  mappings: {
    // ---- top row (main_k1..k10) ----
    main_k1:  { char: ["b", "B"] },
    main_k2:  { char: ["l", "L"] },
    main_k3:  { char: ["d", "D"] },
    main_k4:  { char: ["c", "C"] },
    main_k5:  { char: ["v", "V"] },
    main_k6:  { char: ["z", "Z"] },
    main_k7:  { char: ["y", "Y"] },
    main_k8:  { char: ["o", "O"] },
    main_k9:  { char: ["u", "U"] },
    main_k10: { char: [",", "<"] },

    // ---- home row (main_k11..k20) ----
    main_k11: { char: ["n", "N"] },
    main_k12: { char: ["r", "R"] },
    main_k13: { char: ["t", "T"] },
    main_k14: { char: ["s", "S"] },
    main_k15: { char: ["g", "G"] },
    main_k16: { char: ["p", "P"] },
    main_k17: { char: ["h", "H"] },
    main_k18: { char: ["a", "A"] },
    main_k19: { char: ["e", "E"] },
    main_k20: { char: ["i", "I"] },

    // ---- bottom row (main_k21..k30) ----
    main_k21: { char: ["q", "Q"] },
    main_k22: { char: ["x", "X"] },
    main_k23: { char: ["m", "M"] },
    main_k24: { char: ["w", "W"] },
    main_k25: { char: ["j", "J"] },
    main_k26: { char: ["k", "K"] },
    main_k27: { char: ["f", "F"] },
    main_k28: { char: ["'", "\""] },
    main_k29: { char: [";", ":"] },
    main_k30: { char: [".", ">"] },

    // ---- number row (main_k31..k40) ----
    main_k31: { char: ["1", "!"] },
    main_k32: { char: ["2", "@"] },
    main_k33: { char: ["3", "#"] },
    main_k34: { char: ["4", "$"] },
    main_k35: { char: ["5", "%"] },
    main_k36: { char: ["6", "^"] },
    main_k37: { char: ["7", "&"] },
    main_k38: { char: ["8", "*"] },
    main_k39: { char: ["9", "("] },
    main_k40: { char: ["0", ")"] },

    // ---- named mods (for boards that have them) ----
    mods_tab:         { named: "tab" },
    mods_capslock:    { named: "capslock" },
    mods_shift_left:  { named: "shift" },
    mods_shift_right: { named: "shift" },
    mods_enter:       { named: "enter" },
    mods_backspace:   { named: "backspace" },
  },
}
