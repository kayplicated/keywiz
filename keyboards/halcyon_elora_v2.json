    {
      type: "col-stag",
      cluster: "main",
      keys: [
        // ---- top alpha row (r = -1), main_k1..k10 ----
        { id: "main_k1",  r: -1, c: -5, x: -5.0, y: -0.25, finger: "LPinky" },
        { id: "main_k2",  r: -1, c: -4, x: -4.0, y: -1.25, finger: "LRing" },
        { id: "main_k3",  r: -1, c: -3, x: -3.0, y: -1.5,  finger: "LMiddle" },
        { id: "main_k4",  r: -1, c: -2, x: -2.0, y: -1.25, finger: "LIndex" },
        { id: "main_k5",  r: -1, c: -1, x: -1.0, y: -1.0,  finger: "LIndex" },
        { id: "main_k6",  r: -1, c:  1, x:  1.0, y: -1.0,  finger: "RIndex" },
