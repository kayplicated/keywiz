        { id: "main_k9",  r: -1, c:  4, x:  4.0, y: -1.25, finger: "RRing" },
        { id: "main_k10", r: -1, c:  5, x:  5.0, y: -0.25, finger: "RPinky" },

        // ---- home row (r = 0), main_k11..k20 ----
